# Copy to .env to configure. ALL VALUES ARE OPTIONAL — with no .env the service
# runs against the keyless public OSRM server.

# Routing provider: "ors" | "osrm" | "" (auto: uses ORS when ORS_API_KEY is set, else OSRM)
ROUTING_PROVIDER=

# Free OpenRouteService key (https://openrouteservice.org/dev/#/signup). Optional.
# When set (and ROUTING_PROVIDER is "" or "ors"), the robust ORS provider is used.
ORS_API_KEY=

# Vehicle / algorithm tunables (defaults match the assignment).
VEHICLE_RANGE_MILES=500
VEHICLE_MPG=10
CORRIDOR_BUFFER_MILES=7

# Django. DEBUG=True is for local development only; leaving it unset (or False)
# in production activates the security hardening + boot guards in settings.py.
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-me-in-production
# Comma-separated; REQUIRED when DEBUG=False.
ALLOWED_HOSTS=

# Shared cache + throttle store for multi-process deployments. When set, route
# geometry, plan responses, and rate-limit counters are shared across workers
# (so the "one routing call per route" budget holds globally). Leave blank to
# use the per-process in-memory cache (fine for single-process dev).
REDIS_URL=

# Per-IP (anon) / per-user request rate limits for the API endpoint.
ANON_THROTTLE_RATE=30/min
USER_THROTTLE_RATE=120/min

# Log verbosity for the app loggers (routing / trips / stations).
LOG_LEVEL=INFO
